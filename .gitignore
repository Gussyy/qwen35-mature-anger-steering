# ----- Secrets & venv (NEVER commit) -----
.env
.env.*
.venv/
venv/
env/

# ----- Claude agent state -----
.claude/
.claude-*

# ----- Python bytecode -----
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints/

# ----- HuggingFace / model caches (too big, re-downloaded) -----
.cache/
~/.cache/
hf_cache/

# ----- Training logs & runtime artifacts -----
*.log
wandb/

# ----- Large binary artifacts (upload to HuggingFace instead) -----
# SAE checkpoints are 30-130 MB each
saes/*.pt
saes/*.safetensors
# Ridge transfer map is ~24 MB
vectors/transfer_map_large_to_small.pt

# ----- OS cruft -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Editor / IDE -----
.vscode/
.idea/
*.swp
*.swo
*~

